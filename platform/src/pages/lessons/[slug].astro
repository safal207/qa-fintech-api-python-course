---
import CourseShell from '../../components/CourseShell.astro';
import { lessons } from '../../data/lessons';

export function getStaticPaths() {
  return lessons.map((lesson) => ({ params: { slug: lesson.slug }, props: { lesson } }));
}

const { lesson } = Astro.props;
const currentIndex = lessons.findIndex((item) => item.slug === lesson.slug);
const prev = lessons[currentIndex - 1];
const next = lessons[currentIndex + 1];
const progressPercent = Math.round(((currentIndex + 1) / lessons.length) * 100);
---

<CourseShell title={`${lesson.title} | QA FinTech Course`}>
  <main class="mx-auto grid min-h-screen w-full max-w-7xl gap-5 px-4 py-4 safe-bottom sm:px-6 sm:py-6 lg:grid-cols-[280px_1fr] lg:gap-6 lg:px-10 lg:py-8">
    <aside class="hidden rounded-[1.5rem] border border-slate-700/70 bg-slate-950/50 p-5 shadow-soft backdrop-blur lg:sticky lg:top-8 lg:block lg:h-[calc(100vh-4rem)]">
      <a class="text-sm font-semibold text-sky-200" href="/qa-fintech-api-python-course/">← Course home</a>
      <div class="mt-6 space-y-2">
        {lessons.map((item, index) => (
          <a class:list={['block rounded-2xl border px-4 py-3 transition', item.slug === lesson.slug ? 'border-sky-300 bg-sky-400/10 text-white' : 'border-slate-700/60 bg-slate-900/40 text-slate-300 hover:border-sky-400/60']} href={`/qa-fintech-api-python-course/lessons/${item.slug}/`}>
            <span class="text-xs text-slate-500">{String(index + 1).padStart(2, '0')}</span>
            <p class="mt-1 font-medium">{item.title}</p>
          </a>
        ))}
      </div>
    </aside>

    <article class="space-y-5 sm:space-y-6">
      <nav class="rounded-[1.25rem] border border-slate-700/70 bg-slate-950/70 p-3 shadow-soft backdrop-blur lg:hidden">
        <div class="flex items-center justify-between gap-3 px-1 text-sm">
          <a class="font-semibold text-sky-200" href="/qa-fintech-api-python-course/">← Home</a>
          <span class="text-slate-400">{currentIndex + 1}/{lessons.length}</span>
        </div>
        <div class="mt-3 h-2 overflow-hidden rounded-full bg-slate-800">
          <div class="h-full rounded-full bg-sky-400" style={`width: ${progressPercent}%`}></div>
        </div>
        <div class="mobile-scroll -mx-3 mt-3 flex snap-x gap-2 overflow-x-auto px-3 pb-1">
          {lessons.map((item, index) => (
            <a class:list={['min-w-max snap-start rounded-full border px-3 py-2 text-sm transition', item.slug === lesson.slug ? 'border-sky-300 bg-sky-400/10 text-white' : 'border-slate-700 bg-slate-900/60 text-slate-300']} href={`/qa-fintech-api-python-course/lessons/${item.slug}/`}>
              {String(index + 1).padStart(2, '0')}
            </a>
          ))}
        </div>
      </nav>

      <section class="rounded-[1.5rem] border border-slate-700/70 bg-slate-950/50 p-5 shadow-soft backdrop-blur sm:rounded-[2rem] sm:p-8">
        <p class="inline-flex rounded-full border border-emerald-400/30 bg-emerald-400/10 px-3 py-2 text-xs font-medium text-emerald-200 sm:px-4 sm:text-sm">{lesson.tag}</p>
        <h1 class="mt-5 text-3xl font-semibold tracking-tight text-white sm:mt-6 sm:text-4xl md:text-5xl">{lesson.title}</h1>
        <div class="mt-6 space-y-4 text-base leading-7 text-slate-300 sm:mt-8 sm:text-lg sm:leading-8">
          {lesson.body.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </section>

      <section class="grid gap-5 lg:grid-cols-[1fr_0.9fr] lg:gap-6">
        <div class="rounded-[1.25rem] border border-slate-700/70 bg-slate-900/60 p-5 sm:rounded-[1.5rem] sm:p-6">
          <h2 class="text-xl font-semibold text-white sm:text-2xl">Практика</h2>
          <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-300 sm:mt-5 sm:text-base">
            {lesson.tasks.map((task) => <li class="rounded-xl border border-slate-700/50 bg-slate-950/40 px-4 py-3">✓ {task}</li>)}
          </ul>
        </div>

        <div class="rounded-[1.25rem] border border-slate-700/70 bg-slate-900/60 p-5 sm:rounded-[1.5rem] sm:p-6">
          <h2 class="text-xl font-semibold text-white sm:text-2xl">Команда</h2>
          <pre class="mobile-scroll mt-4 overflow-x-auto rounded-2xl border border-slate-700/60 bg-slate-950 p-4 text-xs leading-6 text-sky-100 sm:mt-5 sm:text-sm sm:leading-7"><code>{lesson.command}</code></pre>
        </div>
      </section>

      <nav class="grid gap-3 pb-2 sm:flex sm:flex-wrap sm:justify-between">
        {prev ? <a class="flex min-h-12 items-center justify-center rounded-2xl border border-slate-600 px-5 py-3 text-center font-semibold text-slate-100 hover:border-sky-300" href={`/qa-fintech-api-python-course/lessons/${prev.slug}/`}>← {prev.title}</a> : <span></span>}
        {next ? <a class="flex min-h-12 items-center justify-center rounded-2xl bg-sky-400 px-5 py-3 text-center font-semibold text-slate-950 hover:bg-sky-300" href={`/qa-fintech-api-python-course/lessons/${next.slug}/`}>{next.title} →</a> : <a class="flex min-h-12 items-center justify-center rounded-2xl bg-emerald-400 px-5 py-3 text-center font-semibold text-slate-950" href="https://github.com/safal207/qa-fintech-api-python-course">Finish on GitHub</a>}
      </nav>
    </article>
  </main>
</CourseShell>
